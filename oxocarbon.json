{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "base00": "#161616",
    "base01": "#262626",
    "base02": "#393939",
    "base03": "#525252",
    "base04": "#dde1e6",
    "base05": "#f2f4f8",
    "base06": "#ffffff",
    "base07": "#08bdba",
    "base08": "#3ddbd9",
    "base09": "#78a9ff",
    "base0A": "#ee5396",
    "base0B": "#33b1ff",
    "base0C": "#ff7eb6",
    "base0D": "#42be65",
    "base0E": "#be95ff",
    "base0F": "#82cfff",
    "base00-light": "#f2f4f8",
    "base01-light": "#dde1e6",
    "base02-light": "#525252",
    "base03-light": "#161616",
    "base04-light": "#262626",
    "base05-light": "#393939",
    "base06-light": "#525252",
    "base07-light": "#08bdba",
    "base08-light": "#ff7eb6",
    "base09-light": "#ee5396",
    "base0A-light": "#FF6F00",
    "base0B-light": "#0f62fe",
    "base0C-light": "#673AB7",
    "base0D-light": "#42be65",
    "base0E-light": "#be95ff",
    "base0F-light": "#37474F",
    "red": "#fa4d56",
    "red-light": "#da1e28",
    "orange": "#ff832b",
    "orange-light": "#ba5e00",
    "gray10": "#f4f4f4",
    "gray20": "#c6c6c6",
    "gray30": "#a8a8a8",
    "gray40": "#8d8d8d",
    "gray50": "#6f6f6f",
    "gray60": "#525252",
    "gray70": "#393939",
    "gray80": "#262626",
    "gray90": "#161616",
    "gray100": "#0d0d0d"
  },
  "theme": {
    "primary": {
      "dark": "base09",
      "light": "base0B-light",
      "description": "Accent elements, links, buttons, active states"
    },
    "secondary": {
      "dark": "base0F",
      "light": "base0F-light",
      "description": "Secondary accents, less prominent interactive elements"
    },
    "accent": {
      "dark": "base07",
      "light": "base07-light",
      "description": "Highlight, active element glow, selection"
    },
    "error": {
      "dark": "red",
      "light": "red-light",
      "description": "Error messages, destructive actions, validation failures"
    },
    "warning": {
      "dark": "orange",
      "light": "orange-light",
      "description": "Warnings, deprecation notices, caution states"
    },
    "success": {
      "dark": "base0D",
      "light": "base0D-light",
      "description": "Success messages, completed operations, positive states"
    },
    "info": {
      "dark": "base09",
      "light": "base0B-light",
      "description": "Informational messages, help text, hints"
    },
    "text": {
      "dark": "base05",
      "light": "base05-light",
      "description": "Primary text content"
    },
    "textMuted": {
      "dark": "base03",
      "light": "base02-light",
      "description": "Secondary text, placeholders, disabled text"
    },
    "background": {
      "dark": "base00",
      "light": "base00-light",
      "description": "Main application background"
    },
    "backgroundPanel": {
      "dark": "base01",
      "light": "base01-light",
      "description": "Sidebar, panel, and card backgrounds"
    },
    "backgroundElement": {
      "dark": "base01",
      "light": "base01-light",
      "description": "Input fields, button, and element backgrounds"
    },
    "border": {
      "dark": "base02",
      "light": "#c6c6c6",
      "description": "Element borders and dividers"
    },
    "borderActive": {
      "dark": "base09",
      "light": "base0B-light",
      "description": "Focused/active element border, selection outline"
    },
    "borderSubtle": {
      "dark": "base02",
      "light": "#e0e0e0",
      "description": "Subtle separators, faint dividing lines"
    },
    "diffAdded": {
      "dark": "base0D",
      "light": "base0D-light",
      "description": "Added line text color"
    },
    "diffRemoved": {
      "dark": "red",
      "light": "red-light",
      "description": "Removed line text color"
    },
    "diffContext": {
      "dark": "base03",
      "light": "gray40",
      "description": "Unchanged context line text color"
    },
    "diffHunkHeader": {
      "dark": "base03",
      "light": "gray30",
      "description": "Hunk header (@@ ... @@) text color"
    },
    "diffHighlightAdded": {
      "dark": "base0D",
      "light": "base0D-light",
      "description": "Highlighted added text within a line (word diff)"
    },
    "diffHighlightRemoved": {
      "dark": "red",
      "light": "red-light",
      "description": "Highlighted removed text within a line (word diff)"
    },
    "diffAddedBg": {
      "dark": "#1c2e1c",
      "light": "#e8f5e9",
      "description": "Added line background"
    },
    "diffRemovedBg": {
      "dark": "#2e1c1c",
      "light": "#fde8e8",
      "description": "Removed line background"
    },
    "diffContextBg": {
      "dark": "base01",
      "light": "base01-light",
      "description": "Unchanged context line background"
    },
    "diffLineNumber": {
      "dark": "base02",
      "light": "gray40",
      "description": "Line number gutter text color"
    },
    "diffAddedLineNumberBg": {
      "dark": "#1c2e1c",
      "light": "#e8f5e9",
      "description": "Added line number gutter background"
    },
    "diffRemovedLineNumberBg": {
      "dark": "#2e1c1c",
      "light": "#fde8e8",
      "description": "Removed line number gutter background"
    },
    "markdownText": {
      "dark": "base05",
      "light": "base05-light",
      "description": "Body text color"
    },
    "markdownHeading": {
      "dark": "base09",
      "light": "base0B-light",
      "description": "Heading (#, ##, etc.) text color"
    },
    "markdownLink": {
      "dark": "base0F",
      "light": "base0B-light",
      "description": "Link URL and bracket color"
    },
    "markdownLinkText": {
      "dark": "base07",
      "light": "base07-light",
      "description": "Link display text color"
    },
    "markdownCode": {
      "dark": "base0A",
      "light": "base09-light",
      "description": "Inline code (`code`) text color"
    },
    "markdownBlockQuote": {
      "dark": "base03",
      "light": "gray40",
      "description": "Blockquote text color"
    },
    "markdownEmph": {
      "dark": "base07",
      "light": "base07-light",
      "description": "Italic/emphasis text color"
    },
    "markdownStrong": {
      "dark": "base06",
      "light": "#000000",
      "description": "Bold/strong text color"
    },
    "markdownHorizontalRule": {
      "dark": "base02",
      "light": "gray30",
      "description": "Horizontal rule (---) color"
    },
    "markdownListItem": {
      "dark": "base09",
      "light": "base0B-light",
      "description": "Unordered list bullet marker color"
    },
    "markdownListEnumeration": {
      "dark": "base07",
      "light": "base07-light",
      "description": "Ordered list number color"
    },
    "markdownImage": {
      "dark": "base0F",
      "light": "base0B-light",
      "description": "Image syntax brackets color"
    },
    "markdownImageText": {
      "dark": "base07",
      "light": "base07-light",
      "description": "Image alt text color"
    },
    "markdownCodeBlock": {
      "dark": "base05",
      "light": "base05-light",
      "description": "Fenced code block text color"
    },
    "syntaxComment": {
      "dark": "base03",
      "light": "gray40",
      "description": "Comments (//, /* */, #)"
    },
    "syntaxKeyword": {
      "dark": "base0E",
      "light": "base0E-light",
      "description": "Keywords (if, for, return, import, class)"
    },
    "syntaxFunction": {
      "dark": "base09",
      "light": "base0B-light",
      "description": "Function and method names"
    },
    "syntaxVariable": {
      "dark": "base0C",
      "light": "base0C-light",
      "description": "Variables, parameters, and identifiers"
    },
    "syntaxString": {
      "dark": "base0D",
      "light": "base0D-light",
      "description": "String literals"
    },
    "syntaxNumber": {
      "dark": "base0A",
      "light": "base09-light",
      "description": "Numeric literals"
    },
    "syntaxType": {
      "dark": "base07",
      "light": "base07-light",
      "description": "Types, classes, interfaces, type annotations"
    },
    "syntaxOperator": {
      "dark": "base0E",
      "light": "base0E-light",
      "description": "Operators (+, ->, =, ===, ?)"
    },
    "syntaxPunctuation": {
      "dark": "base05",
      "light": "base05-light",
      "description": "Punctuation ({, }, (, ), ;, ,)"
    }
  }
}
